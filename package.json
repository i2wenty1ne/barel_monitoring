{
  "name": "barrel-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop application foundation for production barrel monitoring.",
  "author": "Barrel Monitor",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "rebuild:native": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win",
    "dist:win": "npm run build:win"
  },
  "productName": "Barrel Monitor",
  "build": {
    "appId": "com.barrelmonitor.app",
    "productName": "Barrel Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "artifactName": "Barrel-Monitor-${version}-${os}-${arch}.${ext}",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.1",
    "modbus-serial": "^8.0.25",
    "motion": "12.40.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.18.0",
    "serialport": "^13.0.0",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "electron": "42.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "5.0.0",
    "typescript": "5.9.3",
    "vite": "7.3.5"
  }
}
